{
  "name": "subagent007-pi",
  "version": "0.1.0",
  "description": "Private MCP server for one-shot and persistent Pi-backed subagent invocations.",
  "private": true,
  "type": "module",
  "bin": {
    "subagent007-pi": "./dist/server.js"
  },
  "scripts": {
    "clean:dist": "node scripts/build-atomic.mjs --clean-inactive",
    "build": "node scripts/build-atomic.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "pretest:local": "npm run build",
    "test:local": "node scripts/run-tests-with-ledger-guard.mjs tests/*.test.ts",
    "pretest": "npm run build",
    "test": "node scripts/run-tests-with-ledger-guard.mjs tests/*.test.ts",
    "preconfig:migrate": "npm run build",
    "config:migrate": "node scripts/migrate-config.mjs",
    "premodels:reconcile": "npm run build",
    "models:reconcile": "node scripts/reconcile-models.mjs",
    "premodel-health:probe": "npm run build",
    "model-health:probe": "node scripts/probe-model-health.mjs",
    "runtime:readiness": "node scripts/check-runtime-readiness.mjs",
    "docs:check": "node scripts/check-docs-runtime-facts.mjs",
    "observed-campaign": "node scripts/run-observed-campaign.mjs",
    "observed-mcp-probe": "node scripts/run-observed-mcp-probe.mjs",
    "failure-log:archive": "node scripts/archive-failure-log.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.1",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.38",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}

  "scenarios": {
    "tool-listing": {
      "tool": "__list_tools",
      "lifecycle_phases": ["tool-discovery"],
      "result_classes": ["success"],
      "surfaces": ["tool-listing"]
    },
    "model-listing": {
      "tool": "list_model_classes",
      "lifecycle_phases": ["model-class-listing"],
      "result_classes": ["success"],
      "surfaces": ["model-class-listing"]
    },
    "success": {
      "tool": "run_subagent",
      "lifecycle_phases": ["one-shot-success"],
      "result_classes": ["success"],
      "surfaces": ["run_subagent-success"]
    },
    "schema-error": {
      "tool": "run_subagent",
      "lifecycle_phases": ["sdk-schema-validation"],
      "result_classes": ["schema_error"],
      "surfaces": ["run_subagent-schema-error"]
    },
    "handler-validation": {
      "tool": "run_subagent",
      "lifecycle_phases": ["handler-validation"],
      "result_classes": ["preflight_rejected"],
      "surfaces": ["run_subagent-preflight-rejection"]
    },
    "child-failure": {
      "tool": "run_subagent",
      "lifecycle_phases": ["child-process-terminal"],
      "result_classes": ["nonzero_exit"],
      "surfaces": ["run_subagent-child-failure"]
    },
    "packet-failure": {
      "tool": "run_subagent_session",
      "lifecycle_phases": ["session-attempt", "packet-required-gate"],
      "result_classes": ["packet_failed"],
      "surfaces": ["run_subagent_session-packet-failure"]
    },
    "transcript-redaction": {
      "tool": "run_subagent",
      "lifecycle_phases": ["transcript-rendering"],
      "result_classes": ["transcript_redacted"],
      "surfaces": ["transcript-redaction"]
    },
    "timeout-recovery": {
      "tool": "run_subagent",
      "lifecycle_phases": ["one-shot-timeout", "timeout-recovery"],
      "result_classes": ["timeout_recovered"],
      "surfaces": ["run_subagent-timeout-recovery"]
    },
    "start-run-async-polling": {
      "tool": "start_run",
      "lifecycle_phases": ["async-start", "polling", "terminal-snapshot"],
      "result_classes": ["async_polling"],
      "surfaces": ["start_run-async-polling"]
    },
    "schedule-run-durable-first": {
      "tool": "schedule_run",
      "lifecycle_phases": ["scheduler-start", "async-start", "polling", "terminal-snapshot"],
      "result_classes": ["scheduled_durable"],
      "surfaces": ["schedule_run-durable-first"]
    },
    "caller-input": {
      "tool": "answer_run_input",
      "lifecycle_phases": ["async-start", "caller-input", "input-settlement"],
      "result_classes": ["input_answered"],
      "surfaces": ["answer_run_input-caller-input"]
    },
    "cancellation": {
      "tool": "cancel_run",
      "lifecycle_phases": ["async-start", "cancellation", "terminal-snapshot"],
      "result_classes": ["cancelled"],
      "surfaces": ["cancel_run-cancellation-settlement"]
    },
    "session-valid-closure": {
      "tool": "run_subagent_session",
      "lifecycle_phases": ["session-attempt", "packet-required-gate", "packet-closure"],
      "result_classes": ["valid_packet_closure"],
      "surfaces": ["run_subagent_session-valid-packet-closure"]
    },
    "session-invalid-closure": {
      "tool": "run_subagent_session",
      "lifecycle_phases": ["session-attempt", "packet-required-gate", "packet-closure"],
      "result_classes": ["invalid_packet_closure"],
      "surfaces": ["run_subagent_session-invalid-packet-closure"]
    },
    "installed-pi-integration": {
      "tool": "run_subagent",
      "lifecycle_phases": ["installed-pi-child", "one-shot-success"],
      "result_classes": ["success"],
      "surfaces": ["installed-pi-integration"]
    }
  },
  "profiles": {
